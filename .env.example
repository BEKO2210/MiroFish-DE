# ===========================================
# LLM Konfiguration
# ===========================================

# Provider: 'openai' für OpenAI/Cloud-APIs, 'lmstudio'/'ollama'/'local' für lokale LLMs
LLM_PROVIDER=openai

# --- Option 1: OpenAI oder OpenAI-kompatible Cloud-API (z.B. Azure, DashScope) ---
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# --- Option 2: Lokaler LLM-Server (LM Studio, Ollama, etc.) ---
# Wenn LLM_PROVIDER=lmstudio/ollama/local ist, werden folgende Einstellungen verwendet:
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_LLM_MODEL_NAME=whiterabbitneo-2.5-qwen-2.5-coder-7b
LOCAL_LLM_API_KEY=not-needed-for-local-llm

# Beispiel für LM Studio:
# LLM_PROVIDER=lmstudio
# LOCAL_LLM_BASE_URL=http://localhost:1234/v1
# LOCAL_LLM_MODEL_NAME=loaded-model-name

# Beispiel für Ollama:
# LLM_PROVIDER=ollama
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL_NAME=llama3.1

# ===========================================
# ZEP Konfiguration (Erforderlich für Wissensgraphen)
# ===========================================
# Registriere dich kostenlos: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===========================================
# Server Konfiguration (Optional)
# ===========================================
# FLASK_PORT=5002
# FLASK_DEBUG=True

# ===========================================
# Erweiterte LLM-Einstellungen (Optional)
# ===========================================
# REPORT_AGENT_MAX_TOOL_CALLS=5
# REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
# REPORT_AGENT_TEMPERATURE=0.5
